{
  "name": "mem-plugin-obsidian",
  "version": "0.1.23",
  "description": "Obsidian plugin for LLM Build — compiles your vault into a queryable knowledge base via pluggable compilers (NotebookLM / Anthropic / OpenAI / Gemini / Custom).",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node --test tests/notebooklmAuth.test.mjs tests/bundle-smoke.test.mjs",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "release": "bash scripts/bump.sh",
    "release:minor": "bash scripts/bump.sh minor",
    "release:major": "bash scripts/bump.sh major"
  },
  "keywords": [
    "obsidian",
    "llm",
    "memory",
    "notebooklm",
    "knowledge-base"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.0.0",
    "notebooklm-client": "^0.2.0",
    "openai": "^4.65.0"
  }
}
